# Copy to .env.local and adjust. NEXT_PUBLIC_* values are inlined into the client
# bundle at build time (required for the static export).
#
# Demo engagement admin credentials (used by /admin).
# NOTE: this is a STATIC build — these values ship in the JS bundle, so this is a
# convenience gate, not real security. For a truly protected admin, use the
# full-stack option (API routes + server-side auth).
NEXT_PUBLIC_ADMIN_USER=admin
NEXT_PUBLIC_ADMIN_PASS=aurelia2026

# Canonical origin for absolute URLs (schema.org / sitemap).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
