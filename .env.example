# Copy to .env and adjust. NEXT_PUBLIC_* values are inlined into the client
# bundle at build time.

# ── Database ────────────────────────────────────────────────────────────────
# LOCAL dev: SQLite, zero-config (schema prisma/dev.prisma). File at prisma/dev.db.
DATABASE_URL="file:./dev.db"
#
# Both local and prod use PostgreSQL now (schema prisma/dev.prisma). Locally,
# point DATABASE_URL at your Railway Postgres. On Vercel, set DATABASE_URL in the
# dashboard (Settings → Environment Variables) to the Railway PUBLIC URL, e.g.:
#   postgresql://postgres:PASS@monorail.proxy.rlwy.net:PORT/railway
# (Use Railway's *public* URL, not the internal railway.internal one, so Vercel
#  can reach it. Add ?sslmode=require if the connection is rejected.)

# ── Admin auth (real server-side session) ───────────────────────────────────
# Seeded into the AdminUser table on first run. Sign in at /admin/login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=aurelia2026
# Secret used to HMAC-sign the admin session cookie. CHANGE THIS in production.
SESSION_SECRET=change-me-dev-secret-0123456789abcdef0123456789abcdef

# ── SEO ─────────────────────────────────────────────────────────────────────
# Canonical origin for absolute URLs (schema.org / sitemap).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
