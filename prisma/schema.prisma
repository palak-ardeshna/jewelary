// ============================================================================
// Aurelia — Fine Jewellery · Canonical Domain Model
// ----------------------------------------------------------------------------
// This is the SOURCE OF TRUTH for the platform's data model (Phase 3).
//
// On the current static Hostinger deployment this schema does not run at
// runtime — the TS interfaces in `src/data/store.ts` mirror it 1:1 and the
// query helpers there stand in for Prisma. When a Node host + PostgreSQL exist
// (Track B), run `prisma migrate` against this file and swap the bodies of the
// `store.ts` query helpers to Prisma calls. Routes/components do not change.
//
// Conventions:
//   • Money is stored as integer *paise* (Int / BigInt), never floats.
//   • Weights are stored in *milligrams* (Int) to avoid float drift; grams are
//     a display concern.
//   • Every model has id / createdAt / updatedAt. History-bearing models add
//     deletedAt (soft delete). Public models carry a unique `slug`.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserStatus { ACTIVE INVITED SUSPENDED DELETED }
enum AddressType { SHIPPING BILLING }

enum Metal { GOLD_YELLOW GOLD_WHITE GOLD_ROSE PLATINUM SILVER PALLADIUM }
enum Purity { K14 K18 K22 K24 PT950 S925 } // 14/18/22/24kt gold, platinum 950, sterling silver
enum SizeKind { RING CHAIN_LENGTH BANGLE BRACELET NONE }
enum GemstoneType { DIAMOND EMERALD RUBY SAPPHIRE PEARL POLKI TOPAZ AMETHYST NONE }
enum GemCut { ROUND PRINCESS OVAL PEAR EMERALD CUSHION MARQUISE HEART ASSCHER RADIANT UNCUT }
enum CertBody { IGI GIA BIS SGL HALLMARK NONE }

enum ProductStatus { DRAFT ACTIVE ARCHIVED OUT_OF_STOCK }
enum StockMovementType { PURCHASE SALE RETURN ADJUSTMENT TRANSFER RESERVE RELEASE }

enum OrderStatus { PENDING CONFIRMED PACKED SHIPPED OUT_FOR_DELIVERY DELIVERED CANCELLED RETURNED REFUNDED }
enum PaymentStatus { CREATED AUTHORIZED CAPTURED FAILED REFUNDED PARTIALLY_REFUNDED }
enum PaymentProvider { RAZORPAY STRIPE PAYPAL COD GIFT_CARD REWARD_POINTS }
enum TransactionType { CHARGE REFUND PAYOUT ADJUSTMENT }

enum DiscountType { PERCENT FIXED FREE_SHIPPING }
enum CouponAppliesTo { ALL CATEGORY COLLECTION PRODUCT }

enum ReturnStatus { REQUESTED APPROVED PICKED_UP RECEIVED REFUNDED REJECTED }
enum AppointmentType { TRY_AT_HOME VIDEO_CALL STORE_VISIT }
enum AppointmentStatus { REQUESTED CONFIRMED COMPLETED CANCELLED NO_SHOW }

enum NotificationChannel { EMAIL SMS WHATSAPP PUSH IN_APP }
enum NotificationStatus { QUEUED SENT DELIVERED FAILED READ }

enum PageStatus { DRAFT PUBLISHED SCHEDULED }
enum MediaType { IMAGE VIDEO MODEL_3D DOCUMENT }

// ─────────────────────────────────────────────────────────────────────────────
// IDENTITY · RBAC
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  phone         String?    @unique
  name          String?
  passwordHash  String?    // null for social-only accounts (Better Auth / Auth.js)
  emailVerified DateTime?
  status        UserStatus @default(ACTIVE)
  avatarUrl     String?
  localeId      String?
  currencyId    String?

  roles         UserRole[]
  addresses     Address[]
  orders        Order[]
  cart          Cart?
  wishlist      WishlistItem[]
  reviews       Review[]
  appointments  Appointment[]
  rewardAccount RewardAccount?
  referralsMade Referral[]     @relation("Referrer")
  referredBy    Referral?      @relation("Referred")
  notifications Notification[]
  activityLogs  ActivityLog[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  sessions      Session[]

  locale   Language? @relation(fields: [localeId], references: [id])
  currency Currency? @relation(fields: [currencyId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique // OWNER, ADMIN, MANAGER, SUPPORT, EDITOR, CUSTOMER
  description String?
  isSystem    Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id        String           @id @default(cuid())
  key       String           @unique // e.g. "product.create", "order.refund"
  group     String           // e.g. "product", "order"
  roles     RolePermission[]
  createdAt DateTime         @default(now())
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CATALOGUE · CATEGORIES · COLLECTIONS · BRANDS
// ─────────────────────────────────────────────────────────────────────────────

model Brand {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  logoUrl   String?
  about     String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  seo         Seo?       @relation(fields: [seoId], references: [id])
  seoId       String?    @unique
  position    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([parentId])
}

// Curated + programmatic collections. `filterJson` stores the CollectionFilter
// (category/metal/gemstone/price/gender). Indexability is computed by the
// quality guard (see src/lib/collections.ts) and cached in `indexable`.
model Collection {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  intro        String?  @db.Text
  filterJson   Json
  isCurated    Boolean  @default(false)
  indexable    Boolean  @default(false)
  seo          Seo?     @relation(fields: [seoId], references: [id])
  seoId        String?  @unique
  heroMediaId  String?
  heroMedia    Media?   @relation(fields: [heroMediaId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS · VARIANTS · JEWELLERY ATTRIBUTES · MEDIA · PRICING
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  description    String         @db.Text
  status         ProductStatus  @default(ACTIVE)
  gender         String?        // WOMEN | MEN | UNISEX | KIDS
  collectionLine String?        // marketing line e.g. "Solitaire", "Everyday Gold"

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  brandId    String?
  brand      Brand?   @relation(fields: [brandId], references: [id])

  // Default/representative attributes (variants may override)
  metal        Metal?
  purity       Purity?
  grossWeightMg Int?    // milligrams
  netWeightMg   Int?    // milligrams (metal only, excl. stones)
  sizeKind      SizeKind @default(NONE)

  variants       ProductVariant[]
  media          Media[]
  gemstones      Gemstone[]
  certifications Certification[]
  priceBreakup   PriceBreakup?
  reviews        Review[]
  wishlistedBy   WishlistItem[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  stockMovements StockMovement[]
  inventory      Inventory[]
  seo            Seo?     @relation(fields: [seoId], references: [id])
  seoId          String?  @unique

  ratingAvg    Float @default(0)
  reviewCount  Int   @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([categoryId])
  @@index([status])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku           String   @unique
  metal         Metal
  purity        Purity
  size          String?  // "12" ring, "16in" chain, "2.4" bangle
  grossWeightMg Int?
  netWeightMg   Int?
  priceBreakup  PriceBreakup?
  inventory     Inventory[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
}

// Composed price — the way jewellery is actually priced in India.
// finalPaise = metalValue + makingCharge + stoneValue + wastage + gst - discount
model PriceBreakup {
  id            String  @id @default(cuid())
  productId     String? @unique
  product       Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId     String? @unique
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  metalRatePaisePerGram Int   // snapshot of the gold/platinum rate used
  metalValuePaise       Int
  makingChargePaise     Int
  wastagePaise          Int   @default(0)
  stoneValuePaise       Int   @default(0)
  gstPaise              Int
  discountPaise         Int   @default(0)
  finalPaise            Int   // computed total (what the customer pays)
  mrpPaise              Int?
  currencyCode          String @default("INR")

  updatedAt DateTime @updatedAt
}

model Gemstone {
  id         String       @id @default(cuid())
  productId  String
  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  type       GemstoneType
  cut        GemCut?
  caratX100  Int?         // carats × 100 (e.g. 0.75ct = 75)
  clarity    String?      // VVS1, VS2, SI1 ...
  colorGrade String?      // D-Z for diamonds
  count      Int          @default(1)
  createdAt  DateTime     @default(now())

  @@index([productId])
}

model Certification {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  body      CertBody
  number    String?
  url       String?
  createdAt DateTime @default(now())

  @@index([productId])
}

model Media {
  id          String       @id @default(cuid())
  type        MediaType    @default(IMAGE)
  url         String
  alt         String?
  position    Int          @default(0)
  productId   String?
  product     Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  collections Collection[]
  createdAt   DateTime     @default(now())

  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY · WAREHOUSE
// ─────────────────────────────────────────────────────────────────────────────

model Warehouse {
  id         String      @id @default(cuid())
  code       String      @unique
  name       String
  addressId  String?
  address    Address?    @relation(fields: [addressId], references: [id])
  inventory  Inventory[]
  movements  StockMovement[]
  createdAt  DateTime    @default(now())
}

model Inventory {
  id          String          @id @default(cuid())
  warehouseId String
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id])
  productId   String?
  product     Product?        @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  onHand      Int             @default(0)
  reserved    Int             @default(0)
  reorderLevel Int            @default(0)
  updatedAt   DateTime        @updatedAt

  @@unique([warehouseId, variantId])
  @@index([productId])
}

model StockMovement {
  id          String            @id @default(cuid())
  warehouseId String
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id])
  productId   String?
  product     Product?          @relation(fields: [productId], references: [id])
  type        StockMovementType
  quantity    Int
  reference   String?           // order id, return id, PO number
  note        String?
  createdAt   DateTime          @default(now())

  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CART · ORDERS · PAYMENTS
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id])
  sessionId String?    @unique // anonymous carts
  items     CartItem[]
  couponId  String?
  coupon    Coupon?    @relation(fields: [couponId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id         String          @id @default(cuid())
  cartId     String
  cart       Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  quantity   Int             @default(1)
  size       String?
  unitPaise  Int             // snapshot at add-to-cart; revalidated at checkout
  createdAt  DateTime        @default(now())

  @@unique([cartId, productId, variantId, size])
}

model Order {
  id            String        @id @default(cuid())
  number        String        @unique // human-facing e.g. AUR-2026-000123
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  email         String
  phone         String?
  status        OrderStatus   @default(PENDING)

  items         OrderItem[]
  payment       Payment?
  shipment      Shipment?
  return        Return[]

  shippingAddressId String?
  shippingAddress   Address? @relation("OrderShipping", fields: [shippingAddressId], references: [id])
  billingAddressId  String?
  billingAddress    Address? @relation("OrderBilling", fields: [billingAddressId], references: [id])

  subtotalPaise   Int
  discountPaise   Int      @default(0)
  shippingPaise   Int      @default(0)
  taxPaise        Int      @default(0)
  totalPaise      Int
  currencyCode    String   @default("INR")

  couponId   String?
  coupon     Coupon?   @relation(fields: [couponId], references: [id])
  giftCardId String?
  giftCard   GiftCard? @relation(fields: [giftCardId], references: [id])

  placedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  variantId  String?
  variant    ProductVariant? @relation(fields: [variantId], references: [id])
  nameSnapshot String        // denormalised for immutable order history
  skuSnapshot  String?
  size         String?
  quantity     Int           @default(1)
  unitPaise    Int
  totalPaise   Int
}

model Payment {
  id             String          @id @default(cuid())
  orderId        String          @unique
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider       PaymentProvider
  status         PaymentStatus   @default(CREATED)
  providerRef    String?         // razorpay_payment_id / stripe pi / paypal id
  amountPaise    Int
  currencyCode   String          @default("INR")
  idempotencyKey String?         @unique
  transactions   Transaction[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([provider])
}

model Transaction {
  id          String          @id @default(cuid())
  paymentId   String
  payment     Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  type        TransactionType
  amountPaise Int
  providerRef String?
  rawPayload  Json?           // webhook body for audit
  createdAt   DateTime        @default(now())

  @@index([paymentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// FULFILMENT · SHIPPING · TAX · RETURNS
// ─────────────────────────────────────────────────────────────────────────────

model Shipment {
  id           String    @id @default(cuid())
  orderId      String    @unique
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier      String?
  trackingNo   String?
  insuredValuePaise Int  @default(0) // jewellery ships insured
  shippedAt    DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())
}

model ShippingZone {
  id         String         @id @default(cuid())
  name       String
  countryIds String[]       // Country codes covered
  rates      ShippingRate[]
  createdAt  DateTime       @default(now())
}

model ShippingRate {
  id           String       @id @default(cuid())
  zoneId       String
  zone         ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name         String
  pricePaise   Int
  freeAbovePaise Int?
  minDays      Int?
  maxDays      Int?
}

model TaxRate {
  id         String  @id @default(cuid())
  name       String  // e.g. "GST 3% (gold)", "GST 18% (making)"
  countryId  String?
  ratePpm    Int     // rate in parts-per-million (3% = 30000) — avoids float
  appliesTo  String? // metal | making | all
  createdAt  DateTime @default(now())
}

model Return {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id])
  status     ReturnStatus @default(REQUESTED)
  reason     String?
  refundPaise Int?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PROMOTIONS · GIFTING · LOYALTY · REFERRALS
// ─────────────────────────────────────────────────────────────────────────────

model Coupon {
  id             String          @id @default(cuid())
  code           String          @unique
  discountType   DiscountType
  value          Int             // percent (basis points) or paise
  appliesTo      CouponAppliesTo @default(ALL)
  targetId       String?         // category/collection/product id when scoped
  minOrderPaise  Int?
  maxDiscountPaise Int?
  usageLimit     Int?
  usedCount      Int             @default(0)
  perUserLimit   Int?
  startsAt       DateTime?
  endsAt         DateTime?
  isActive       Boolean         @default(true)
  carts          Cart[]
  orders         Order[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model GiftCard {
  id            String   @id @default(cuid())
  code          String   @unique
  initialPaise  Int
  balancePaise  Int
  currencyCode  String   @default("INR")
  recipientEmail String?
  message       String?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  orders        Order[]
  createdAt     DateTime @default(now())
}

model RewardAccount {
  id        String        @id @default(cuid())
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int           @default(0) // points
  ledger    RewardLedger[]
  updatedAt DateTime      @updatedAt
}

model RewardLedger {
  id        String        @id @default(cuid())
  accountId String
  account   RewardAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  delta     Int           // +earn / -redeem
  reason    String
  orderId   String?
  createdAt DateTime      @default(now())
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("Referrer", fields: [referrerId], references: [id])
  referredId  String?  @unique
  referred    User?    @relation("Referred", fields: [referredId], references: [id])
  code        String   @unique
  rewardPaise Int      @default(0)
  convertedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([referrerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMER ENGAGEMENT · REVIEWS · WISHLIST · ADDRESSES · APPOINTMENTS
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  author     String
  rating     Int      // 1..5
  title      String?
  body       String   @db.Text
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Address {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  type       AddressType @default(SHIPPING)
  name       String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  countryId  String
  country    Country     @relation(fields: [countryId], references: [id])
  isDefault  Boolean     @default(false)

  warehouses     Warehouse[]
  ordersShipping Order[]     @relation("OrderShipping")
  ordersBilling  Order[]     @relation("OrderBilling")

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId])
}

model Appointment {
  id        String            @id @default(cuid())
  userId    String?
  user      User?             @relation(fields: [userId], references: [id])
  type      AppointmentType
  status    AppointmentStatus @default(REQUESTED)
  name      String
  email     String
  phone     String
  scheduledAt DateTime
  note      String?
  productSlug String?
  createdAt DateTime          @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// LOCALISATION
// ─────────────────────────────────────────────────────────────────────────────

model Country {
  id         String     @id @default(cuid())
  code       String     @unique // ISO 3166-1 alpha-2
  name       String
  currencyId String?
  currency   Currency?  @relation(fields: [currencyId], references: [id])
  addresses  Address[]
  isActive   Boolean    @default(true)
}

model Currency {
  id         String    @id @default(cuid())
  code       String    @unique // ISO 4217
  symbol     String
  name       String
  rateToBase Int       // rate × 1e6 relative to INR base (avoids float)
  isActive   Boolean   @default(true)
  countries  Country[]
  users      User[]
}

model Language {
  id        String @id @default(cuid())
  code      String @unique // BCP-47 e.g. en-IN, hi-IN
  name      String
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)
  users     User[]
}

// ─────────────────────────────────────────────────────────────────────────────
// CMS · CONTENT · SEO · SITE BUILDERS
// ─────────────────────────────────────────────────────────────────────────────

model Seo {
  id             String      @id @default(cuid())
  title          String?
  description    String?
  canonical      String?
  ogImage        String?
  noindex        Boolean     @default(false)
  jsonLd         Json?
  product        Product?
  category       Category?
  collection     Collection?
  cmsPage        CmsPage?
  blogPost       BlogPost?
}

model CmsPage {
  id        String     @id @default(cuid())
  slug      String     @unique
  title     String
  bodyMdx   String     @db.Text
  status    PageStatus @default(DRAFT)
  seo       Seo?       @relation(fields: [seoId], references: [id])
  seoId     String?    @unique
  publishedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model BlogPost {
  id         String     @id @default(cuid())
  slug       String     @unique
  title      String
  excerpt    String?
  bodyMdx    String     @db.Text
  coverUrl   String?
  authorName String?
  status     PageStatus @default(DRAFT)
  seo        Seo?       @relation(fields: [seoId], references: [id])
  seoId      String?    @unique
  publishedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// Homepage / navigation / footer / theme are stored as ordered JSON blocks so
// the Admin builders can edit them without deploys.
model HomepageSection {
  id        String   @id @default(cuid())
  type      String   // HERO | CATEGORY_GRID | PRODUCT_RAIL | COLLECTION | EDITORIAL | TRUST
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  configJson Json
  updatedAt DateTime @updatedAt
}

model NavigationItem {
  id        String           @id @default(cuid())
  menu      String           // HEADER | FOOTER
  label     String
  href      String
  position  Int              @default(0)
  parentId  String?
  parent    NavigationItem?  @relation("NavTree", fields: [parentId], references: [id])
  children  NavigationItem[] @relation("NavTree")
  isActive  Boolean          @default(true)
}

model ThemeSetting {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "colors", "typography", "radius"
  valueJson Json
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  updatedAt DateTime @updatedAt
}

model Form {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  schemaJson Json        // field definitions
  submissions FormSubmission[]
  createdAt DateTime     @default(now())
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  dataJson  Json
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// MESSAGING · NOTIFICATIONS · TEMPLATES
// ─────────────────────────────────────────────────────────────────────────────

model MessageTemplate {
  id        String              @id @default(cuid())
  key       String              @unique // order_confirmation, abandoned_cart ...
  channel   NotificationChannel
  subject   String?
  body      String              @db.Text // supports handlebars-style vars
  isActive  Boolean             @default(true)
  updatedAt DateTime            @updatedAt
}

model Notification {
  id        String              @id @default(cuid())
  userId    String?
  user      User?               @relation(fields: [userId], references: [id])
  channel   NotificationChannel
  status    NotificationStatus  @default(QUEUED)
  templateKey String?
  payload   Json?
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI CENTER · ANALYTICS · LOGS
// ─────────────────────────────────────────────────────────────────────────────

// Generic log of AI generations (descriptions, SEO, blog, forecasts) for
// auditability, cost tracking, and human review before publish.
model AiGeneration {
  id        String   @id @default(cuid())
  feature   String   // STYLIST | GIFT_FINDER | DESCRIPTION | SEO | BLOG | FORECAST | TAGGING ...
  model     String   // e.g. claude-opus-4-8
  inputJson Json
  output    String   @db.Text
  tokensIn  Int?
  tokensOut Int?
  approved  Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())

  @@index([feature])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String   // page_view, add_to_cart, purchase ...
  sessionId String?
  userId    String?
  path      String?
  propsJson Json?
  createdAt DateTime @default(now())

  @@index([name])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// Immutable audit trail of admin mutations (who changed what, before/after).
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  action     String   // create | update | delete | refund | login ...
  entity     String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
}

model Backup {
  id        String   @id @default(cuid())
  location  String   // S3 key / path
  sizeBytes BigInt?
  status    String   @default("COMPLETED")
  createdAt DateTime @default(now())
}
