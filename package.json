{
  "name": "trendora",
  "version": "0.1.0",
  "private": true,
  "description": "E-commerce SEO storefront — category/collection/product routing with schema automation and safe programmatic collections (static data, no DB)",
  "scripts": {
    "predev": "prisma db push --schema prisma/dev.prisma",
    "dev": "next dev",
    "build": "prisma generate --schema prisma/dev.prisma && next build",
    "prestart": "prisma db push --schema prisma/dev.prisma",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push --schema prisma/dev.prisma",
    "db:generate": "prisma generate --schema prisma/dev.prisma",
    "db:studio": "prisma studio --schema prisma/dev.prisma",
    "db:reset": "prisma db push --force-reset --schema prisma/dev.prisma",
    "postinstall": "prisma generate --schema prisma/dev.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "canvas-confetti": "^1.9.4",
    "cloudinary": "^2.10.0",
    "next": "^15.1.4",
    "pg": "^8.22.0",
    "prisma": "^6.19.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
